{
  "name": "mini-campaign-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "backend": "yarn workspace backend",
    "frontend": "yarn workspace frontend",
    "dev": "concurrently \"yarn dev:backend\" \"yarn dev:frontend\"",
    "dev:backend": "yarn workspace backend dev",
    "dev:frontend": "yarn workspace frontend dev",
    "build": "yarn build:backend && yarn build:frontend",
    "build:backend": "yarn workspace backend build",
    "build:frontend": "yarn workspace frontend build",
    "test": "yarn test:backend && yarn test:frontend",
    "test:backend": "yarn workspace backend test",
    "test:frontend": "yarn workspace frontend test",
    "lint": "yarn workspaces run lint",
    "format": "yarn workspaces run format",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:migrate": "docker-compose up flyway"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  }
}
